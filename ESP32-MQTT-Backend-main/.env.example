FLASK_APP=run.py
FLASK_DEBUG=1
SECRET_KEY=change-me
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please

WECHAT_APPID=
WECHAT_SECRET=
TOKEN_EXPIRE_SECONDS=7200

WECHAT_NOTIFY_ENABLED=False
WECHAT_FALL_ALERT_TEMPLATE_ID=lMimVUwjOa0cH3gTUw-C6O8K2_sNQqdG6sfo4xyZvUs
WECHAT_DEVICE_FAULT_TEMPLATE_ID=yxXEdI_z5VIe86cz32rojUloZGPnKmQVOGyAIsQ-UNM
WECHAT_MINIPROGRAM_STATE=trial
WECHAT_LANG=zh_CN
WECHAT_FALL_ALERT_PAGE=pages/fall-alert/index
WECHAT_DEVICE_FAULT_PAGE=pages/device-detail/index
WECHAT_ACCESS_TOKEN_CACHE_SECONDS=6600

MQTT_ENABLED=0
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_AUTOSTART_DEVICES=0
OFFLINE_MONITOR_ENABLED=1
OFFLINE_TIMEOUT_SECONDS=15
STATUS_TIMEOUT_SECONDS=15
CSI_TIMEOUT_SECONDS=8
CSI_EXPECTED_INTERVAL_SECONDS=1.5
CSI_SOFT_TIMEOUT_SECONDS=10
CSI_RECOVERY_GRACE_SECONDS=20
CSI_HARD_TIMEOUT_SECONDS=35
RUNNING_IGNORE_STATUS_TIMEOUT=True
START_GRACE_SECONDS=10
CSI_PARSE_ERROR_LIMIT=3
CSI_WINDOW_SIZE=5

# Docker fall-detection service
FALL_ALGORITHM_ENABLED=1
FALL_ALGORITHM_HTTP_BASE_URL=http://127.0.0.1:18080
FALL_ALGORITHM_WS_URL=ws://127.0.0.1:18080/stream
FALL_ALGORITHM_HEALTH_PATH=/health
FALL_ALGORITHM_STATS_PATH=/stats
FALL_ALGORITHM_CONFIG_PATH=/config
FALL_ALGORITHM_RESET_PATH=/reset
FALL_ALGORITHM_HTTP_TIMEOUT_SECONDS=3
FALL_ALGORITHM_WS_CONNECT_TIMEOUT_SECONDS=5
FALL_ALGORITHM_WS_READ_TIMEOUT_SECONDS=35
FALL_ALGORITHM_PING_INTERVAL_SECONDS=30
FALL_ALGORITHM_RECONNECT_INITIAL_SECONDS=1
FALL_ALGORITHM_RECONNECT_MAX_SECONDS=30
FALL_ALGORITHM_BATCH_INTERVAL_SECONDS=1.5
FALL_ALGORITHM_QUEUE_MAX_FRAMES=2000
FALL_ALGORITHM_SINGLE_ACTIVE_STREAM=1

# If this Flask backend also runs in Docker, 127.0.0.1 points at the backend
# container itself. Use the algorithm container service name and internal port,
# for example http://fall-detection:5000 and ws://fall-detection:5000/stream.
FALL_ALGORITHM_CSI_TYPE=CSI_DATA
FALL_ALGORITHM_RATE_SIG_MODE=11
FALL_ALGORITHM_CHANNEL=100
FALL_ALGORITHM_FFT_GAIN=0
FALL_ALGORITHM_AGC_GAIN=0
FALL_ALGORITHM_RX_STATE=0
FALL_ALGORITHM_SECONDARY_CHANNEL=0
FALL_ALGORITHM_NOISE_FLOOR=0
FALL_ALGORITHM_PAYLOAD_TYPE=13
