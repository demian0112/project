FLASK_APP=run.py
FLASK_DEBUG=1
SECRET_KEY=replace-this-with-a-random-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-this-with-a-strong-password

# WeChat mini-program credentials. WECHAT_SECRET stays on the backend.
WECHAT_APPID=replace-with-your-mini-program-appid
WECHAT_SECRET=replace-with-your-mini-program-secret
TOKEN_EXPIRE_SECONDS=7200

# Enable this after the backend machine can reach the Mosquitto broker.
MQTT_ENABLED=1
MQTT_HOST=192.168.101.48
MQTT_PORT=1883
MQTT_USERNAME=csi_user
MQTT_PASSWORD=replace-with-the-real-broker-password
OFFLINE_MONITOR_ENABLED=1
OFFLINE_TIMEOUT_SECONDS=15
STATUS_TIMEOUT_SECONDS=15
CSI_TIMEOUT_SECONDS=8
CSI_WINDOW_SIZE=5
FAULT_EVENT_LIMIT_SECONDS=5

# The default database is instance/app.db.
# To override it, use an absolute SQLite URL, for example:
# DATABASE_URL=sqlite:////absolute/path/to/app.db
